# .env.example

# Application
ENV=LOCAL

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=5s

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=authdb
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m

# JWT (Ed25519 - Base64 encoded keys)
JWT_PRIVATE_KEY=your_base64_encoded_32byte_seed_here
JWT_PUBLIC_KEY=your_base64_encoded_32byte_public_key_here
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h
JWT_ISSUER=auth-service
JWT_AUDIENCE=cloud-storage

# Security
SECURITY_BCRYPT_COST=12
SECURITY_MIN_PASSWORD_LENGTH=8
SECURITY_MAX_PASSWORD_LENGTH=72

# CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400