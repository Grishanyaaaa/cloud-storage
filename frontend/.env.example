# API gateway base URL (no trailing slash).
VITE_API_BASE_URL=http://localhost:8080

# Shown in the browser tab title.
VITE_APP_NAME=cloud-storage

# Default tree depth and node limit (matches ai-service eager-context).
VITE_DEFAULT_TREE_DEPTH=10
VITE_TREE_MAX_NODES=500

# Upload manager.
VITE_UPLOAD_PARALLELISM=3
VITE_UPLOAD_PROGRESS_THROTTLE_MS=200

# Public share base URL — substituted into copied share links.
# Example: https://app.cloud-storage.local
VITE_SHARE_BASE_URL=http://localhost:5173
