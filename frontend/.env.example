# Frontend env (Vite-injected at build time). For runtime overrides in
# production deployments, see deployments/docker-entrypoint.sh and
# deployments/k8s/configmap.yaml.

# Root URL of the api-gateway. Use empty string to fetch via same-origin
# (works behind an ingress that routes /auth, /storage, /ai to the
# gateway from the same host as the SPA).
VITE_API_BASE_URL=http://localhost:8080

# Where the SPA is served. Used to rewrite share-link URLs returned by
# storage-service (which embed the gateway host) to the frontend host
# so links like /share/{token} land on the public-share page.
# Defaults to window.location.origin.
VITE_SHARE_BASE_URL=

# Display name (browser tab title, etc.).
VITE_APP_NAME=cloud-storage

# Tree expansion depth on the sidebar (0 = root only).
VITE_DEFAULT_TREE_DEPTH=10

# Maximum nodes the tree query loads at once (server-side limit).
VITE_TREE_MAX_NODES=500

# Concurrent file uploads.
VITE_UPLOAD_PARALLELISM=3

# Throttle for upload-progress events (ms).
VITE_UPLOAD_PROGRESS_THROTTLE_MS=200

# Per-file size cap. storage-service's hard cap is 5 GiB.
VITE_UPLOAD_MAX_BYTES=5368709119
