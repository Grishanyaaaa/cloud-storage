# .env.example

# Application
ENV=LOCAL

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8083
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=30s
SERVER_TRUST_PROXY=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aidb
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m
POSTGRES_CONN_MAX_IDLE_TIME=1m

# JWT (Ed25519 — only public key needed; ai-service verifies, never signs)
JWT_PUBLIC_KEY=your_base64_encoded_32byte_public_key_here
JWT_ISSUER=auth-service
JWT_AUDIENCE=cloud-storage

# storage-service (called via JWT-passthrough; ai-service has no own creds)
STORAGE_SERVICE_BASE_URL=http://storage-service:8082
STORAGE_SERVICE_TIMEOUT=15s
STORAGE_SERVICE_TREE_MAX_DEPTH=10
STORAGE_SERVICE_TREE_MAX_NODES=500

# Yandex GPT (Foundation Models REST API)
YANDEX_GPT_API_KEY=replace_with_yandex_api_key
YANDEX_GPT_FOLDER_ID=replace_with_yandex_folder_id
YANDEX_GPT_MODEL_URI=
YANDEX_GPT_MODEL=yandexgpt/latest
YANDEX_GPT_ENDPOINT=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
YANDEX_GPT_TIMEOUT=60s
YANDEX_GPT_TEMPERATURE=0.1
YANDEX_GPT_MAX_TOKENS=2000

# AI tunables
AI_MAX_INPUT_CHARS=2000
AI_PLAN_TTL=5m
AI_MAX_LLM_RETRIES=1
AI_JANITOR_PLANS_INTERVAL=60s
AI_JANITOR_BATCH_SIZE=500

# CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400
