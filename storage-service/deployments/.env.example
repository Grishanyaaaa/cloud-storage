# .env.example

# Application
ENV=LOCAL

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=30s
SERVER_TRUST_PROXY=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=storagedb
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m
POSTGRES_CONN_MAX_IDLE_TIME=1m

# JWT (Ed25519 — only public key needed; storage-service verifies, never signs)
JWT_PUBLIC_KEY=your_base64_encoded_32byte_public_key_here
JWT_ISSUER=auth-service
JWT_AUDIENCE=cloud-storage

# S3-compatible object storage (MinIO / AWS S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cloud-storage
S3_ACCESS_KEY_ID=minio_access_key
S3_SECRET_ACCESS_KEY=minio_secret_key
S3_USE_PATH_STYLE=true
S3_USE_SSL=false

# Storage service tunables
STORAGE_MAX_FILE_SIZE_BYTES=5368709120
STORAGE_PUBLIC_BASE_URL=http://localhost:8081
STORAGE_JANITOR_PENDING_INTERVAL_SEC=600
STORAGE_JANITOR_SHARES_INTERVAL_SEC=600
STORAGE_JANITOR_BATCH_SIZE=500

# Pre-signed URL TTL (size-based)
TTL_BASE_UPLOAD=5m
TTL_PER_MIB_UPLOAD=5s
TTL_MIN_UPLOAD=5m
TTL_MAX_UPLOAD=6h
TTL_BASE_DOWNLOAD=2m
TTL_PER_MIB_DOWNLOAD=2s
TTL_MIN_DOWNLOAD=2m
TTL_MAX_DOWNLOAD=2h

# CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400
